# Copy this file to .env and fill in your values.
# .env is gitignored — never commit it.

# Gmail credentials for sending alert emails
GMAIL_USER=your_gmail@gmail.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# GitHub Personal Access Token — needed to trigger Actions from the terminal
# Create at: github.com/settings/tokens (Fine-grained, Actions: Read & write)
GITHUB_PAT=github_pat_xxxxxxxxxxxx
